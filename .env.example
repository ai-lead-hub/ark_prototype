# ====================
# Frontend Environment
# ====================

# API Keys for AI providers (required for generation)
VITE_FAL_KEY=your_fal_api_key_here
VITE_KIE_KEY=your_kie_api_key_here
VITE_FREEPIK_KEY=your_freepik_api_key_here

# File API connection (local server)
VITE_FILE_API_BASE=http://localhost:8787
VITE_FILE_API_TOKEN=your_secure_token_here

# ====================
# Server Environment
# ====================

# Server configuration
FILE_API_PORT=8787
FILE_STORAGE_ROOT=./data
FILE_API_TOKEN=your_secure_token_here
FILE_API_CORS_ORIGIN=http://localhost:5173
FILE_MAX_SIZE_MB=256
FREEPIK_API_KEY=optional_server_side_freepik_key

# Optional hardening/runtime controls
FILE_API_REQUIRE_TOKEN=true
FILE_API_TRUST_PROXY=false
FILE_REQUEST_TIMEOUT_MS=120000
FILE_ENABLE_CLIENT_LOG_ENDPOINT=false
FILE_MAX_DEBUG_LOG_BYTES=10485760
FILE_TRASH_CLEAR_ON_START=false
FILE_REQUIRE_META_DB=false
